<Window x:Class="GeolocationAddin.UI.LinkSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GeolocationAddin.Models"
        Title="Select Links to Process"
        Width="850" Height="500"
        MinWidth="600" MinHeight="350"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Row background based on MatchType -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding MatchType}" Value="{x:Static models:MatchType.Exact}">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MatchType}" Value="{x:Static models:MatchType.Fuzzy}">
                    <Setter Property="Background" Value="#FFF8E1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MatchType}" Value="{x:Static models:MatchType.None}">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" x:Name="HeaderText"
                   Margin="12,10" FontSize="13" FontWeight="SemiBold"/>

        <!-- Bottom buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Select All" Margin="0,0,6,0" Padding="8,4"
                        Click="SelectAll_Click"/>
                <Button Content="Deselect All" Margin="0,0,6,0" Padding="8,4"
                        Click="DeselectAll_Click"/>
                <Button Content="Exact Only" Padding="8,4"
                        Click="SelectExactOnly_Click"/>
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Process Selected" IsDefault="True"
                        MinWidth="110" Padding="8,4" Margin="0,0,8,0"
                        Click="ProcessSelected_Click"/>
                <Button Content="Cancel" IsCancel="True"
                        MinWidth="70" Padding="8,4"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="LinksGrid" Margin="12,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="False"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        Header="" Width="30"/>
                <DataGridTextColumn Binding="{Binding InstanceName}"
                                    Header="Instance Name" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Binding="{Binding MatchDescription}"
                                    Header="Match" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Binding="{Binding TargetFileName}"
                                    Header="Target File Name" Width="200" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
