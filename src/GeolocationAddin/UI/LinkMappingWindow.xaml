<Window x:Class="GeolocationAddin.UI.LinkMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GeolocationAddin.Models"
        Title="Link Mapping Editor"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Row background based on MatchType and validation -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding MatchType}" Value="{x:Static models:MatchType.Exact}">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MatchType}" Value="{x:Static models:MatchType.Fuzzy}">
                    <Setter Property="Background" Value="#FFF8E1"/>
                </DataTrigger>
                <!-- Validation error overrides match color -->
                <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                    <Setter Property="Background" Value="#FFCDD2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Bottom buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Validation warning -->
            <TextBlock Grid.Column="0" x:Name="ValidationWarning"
                       Foreground="#D32F2F" VerticalAlignment="Center"
                       Visibility="Collapsed"
                       Text="⚠ Duplicate target file names detected"/>

            <!-- Action buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Process Selected" x:Name="ProcessButton"
                        IsDefault="True" MinWidth="110" Padding="8,4"
                        Margin="0,0,8,0" Click="ProcessSelected_Click"/>
                <Button Content="Cancel" IsCancel="True"
                        MinWidth="70" Padding="8,4" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>

        <!-- Tab control -->
        <TabControl Margin="8,8,8,0">
            <!-- Mappings tab -->
            <TabItem Header="Mappings">
                <DockPanel>
                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,6">
                        <Button Content="Import" Padding="8,4" Margin="0,0,4,0"
                                Click="Import_Click"/>
                        <Button Content="Export" Padding="8,4" Margin="0,0,12,0"
                                Click="Export_Click"/>
                        <Button Content="Select All" Padding="8,4" Margin="0,0,4,0"
                                Click="SelectAll_Click"/>
                        <Button Content="Deselect All" Padding="8,4" Margin="0,0,4,0"
                                Click="DeselectAll_Click"/>
                        <Button Content="Clear All Targets" Padding="8,4"
                                Click="ClearAll_Click"/>
                    </StackPanel>

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top" x:Name="HeaderText"
                               Margin="6,0,6,4" FontSize="13" FontWeight="SemiBold"/>

                    <!-- DataGrid -->
                    <DataGrid x:Name="LinksGrid" Margin="4,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              IsReadOnly="False"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn
                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                Header="" Width="30"/>
                            <DataGridTextColumn
                                Binding="{Binding InstanceName}"
                                Header="Instance Name" Width="*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Target File Name" Width="250">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding TargetFileName, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center"
                                                 Padding="2,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Label" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center"
                                                 Padding="2,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Export View" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ExportViewName, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center"
                                                 Padding="2,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Settings tab -->
            <TabItem Header="Settings">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="8">
                        <Button Content="Save Settings" Width="100" Padding="4"
                                Click="SaveSettings_Click"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Paths -->
                            <GroupBox Header="Paths" Margin="8,4" Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CSV Mapping:"
                                               VerticalAlignment="Center" Margin="0,2"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="CsvMappingPathBox"
                                             Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                                    <Button Grid.Row="0" Grid.Column="2" Content="..."
                                            Width="30" Margin="4,2,0,2" Click="BrowseCsvPath_Click"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Link Source:"
                                               VerticalAlignment="Center" Margin="0,2"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="LinkSourceFolderBox"
                                             Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                                    <Button Grid.Row="1" Grid.Column="2" Content="..."
                                            Width="30" Margin="4,2,0,2"
                                            Click="BrowseFolder_Click" Tag="LinkSourceFolderBox"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Output Folder:"
                                               VerticalAlignment="Center" Margin="0,2"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="OutputFolderBox"
                                             Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                                    <Button Grid.Row="2" Grid.Column="2" Content="..."
                                            Width="30" Margin="4,2,0,2"
                                            Click="BrowseFolder_Click" Tag="OutputFolderBox"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="IFC Output:"
                                               VerticalAlignment="Center" Margin="0,2"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="IfcOutputFolderBox"
                                             Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                                    <Button Grid.Row="3" Grid.Column="2" Content="..."
                                            Width="30" Margin="4,2,0,2"
                                            Click="BrowseFolder_Click" Tag="IfcOutputFolderBox"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="NWC Output:"
                                               VerticalAlignment="Center" Margin="0,2"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="NwcOutputFolderBox"
                                             Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                                    <Button Grid.Row="4" Grid.Column="2" Content="..."
                                            Width="30" Margin="4,2,0,2"
                                            Click="BrowseFolder_Click" Tag="NwcOutputFolderBox"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="DWG Output:"
                                               VerticalAlignment="Center" Margin="0,2"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="DwgOutputFolderBox"
                                             Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                                    <Button Grid.Row="5" Grid.Column="2" Content="..."
                                            Width="30" Margin="4,2,0,2"
                                            Click="BrowseFolder_Click" Tag="DwgOutputFolderBox"/>
                                </Grid>
                            </GroupBox>

                            <!-- Export Settings -->
                            <GroupBox Header="Export Settings" Margin="8,4" Padding="8,4">
                                <StackPanel>
                                    <CheckBox x:Name="ExportIfcCheck" Content="Export IFC" Margin="0,2"
                                              Checked="ExportCheck_Changed" Unchecked="ExportCheck_Changed"/>
                                    <CheckBox x:Name="ExportNwcCheck" Content="Export NWC" Margin="0,2"
                                              Checked="ExportCheck_Changed" Unchecked="ExportCheck_Changed"/>
                                    <CheckBox x:Name="ExportDwgCheck" Content="Export DWG" Margin="0,2"
                                              Checked="ExportCheck_Changed" Unchecked="ExportCheck_Changed"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Fuzzy Matching -->
                            <GroupBox Header="Fuzzy Matching" Margin="8,4" Padding="8,4">
                                <StackPanel>
                                    <CheckBox x:Name="FuzzyEnabledCheck" Content="Enable fuzzy matching"
                                              Margin="0,2"/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Token overlap threshold:"
                                                   VerticalAlignment="Center"/>
                                        <Slider Grid.Row="0" Grid.Column="1"
                                                x:Name="TokenThresholdSlider"
                                                Minimum="0" Maximum="1"
                                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                                Margin="4,0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Text="{Binding Value, ElementName=TokenThresholdSlider, StringFormat={}{0:F2}}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Levenshtein threshold:"
                                                   VerticalAlignment="Center" Margin="0,4,0,0"/>
                                        <Slider Grid.Row="1" Grid.Column="1"
                                                x:Name="LevenshteinThresholdSlider"
                                                Minimum="0" Maximum="1"
                                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                                Margin="4,4,4,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2"
                                                   Text="{Binding Value, ElementName=LevenshteinThresholdSlider, StringFormat={}{0:F2}}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
