<Window x:Class="GeolocationAddin.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geolocation Settings"
        Width="600" Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" x:Key="BrowseButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Margin" Value="4,2,0,2"/>
            <Setter Property="Content" Value="..."/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="8">
            <Button Content="Save" Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="Save_Click"/>
            <Button Content="Cancel" Width="80"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Paths -->
                <GroupBox Header="Paths">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CSV Mapping:"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="CsvMappingPathBox"/>
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource BrowseButton}"
                                Click="BrowseCsvPath_Click"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Link Source:"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="LinkSourceFolderBox"/>
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource BrowseButton}"
                                Click="BrowseFolder_Click" Tag="LinkSourceFolderBox"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Output Folder:"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="OutputFolderBox"/>
                        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource BrowseButton}"
                                Click="BrowseFolder_Click" Tag="OutputFolderBox"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="IFC Output:"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="IfcOutputFolderBox"/>
                        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource BrowseButton}"
                                Click="BrowseFolder_Click" Tag="IfcOutputFolderBox"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="NWC Output:"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="NwcOutputFolderBox"/>
                        <Button Grid.Row="4" Grid.Column="2" Style="{StaticResource BrowseButton}"
                                Click="BrowseFolder_Click" Tag="NwcOutputFolderBox"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="DWG Output:"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="DwgOutputFolderBox"/>
                        <Button Grid.Row="5" Grid.Column="2" Style="{StaticResource BrowseButton}"
                                Click="BrowseFolder_Click" Tag="DwgOutputFolderBox"/>
                    </Grid>
                </GroupBox>

                <!-- Export Settings -->
                <GroupBox Header="Export Settings">
                    <StackPanel>
                        <CheckBox x:Name="ExportIfcCheck" Content="Export IFC" Margin="0,2"
                                  Checked="ExportCheck_Changed" Unchecked="ExportCheck_Changed"/>
                        <CheckBox x:Name="ExportNwcCheck" Content="Export NWC" Margin="0,2"
                                  Checked="ExportCheck_Changed" Unchecked="ExportCheck_Changed"/>
                        <CheckBox x:Name="ExportDwgCheck" Content="Export DWG" Margin="0,2"
                                  Checked="ExportCheck_Changed" Unchecked="ExportCheck_Changed"/>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IFC Config File:"
                                       VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Column="1" x:Name="IfcExportConfigPathBox"
                                     Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource BrowseButton}"
                                    Click="BrowseIfcConfigPath_Click"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Fuzzy Matching -->
                <GroupBox Header="Fuzzy Matching">
                    <StackPanel>
                        <CheckBox x:Name="FuzzyEnabledCheck" Content="Enable fuzzy matching"
                                  Margin="0,2"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Token overlap threshold:"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1"
                                    x:Name="TokenThresholdSlider"
                                    Minimum="0" Maximum="1"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Margin="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Value, ElementName=TokenThresholdSlider, StringFormat={}{0:F2}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Levenshtein threshold:"
                                       VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <Slider Grid.Row="1" Grid.Column="1"
                                    x:Name="LevenshteinThresholdSlider"
                                    Minimum="0" Maximum="1"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Margin="4,4,4,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="{Binding Value, ElementName=LevenshteinThresholdSlider, StringFormat={}{0:F2}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
